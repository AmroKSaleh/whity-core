APP_ENV=development
DB_USER=whity
DB_PASSWORD=whity_dev
DB_NAME=whity_core
DB_HOST=postgres
DB_PORT=5432
# JWT signing secret. Required (and must be >= 32 chars) outside APP_ENV=development.
JWT_SECRET=dev_secret_key_change_in_production
# AES-256-CBC key used to encrypt stored TOTP 2FA secrets (WC-95). Required (and must
# be >= 32 chars) outside APP_ENV=development; in development the app falls back to an
# insecure hardcoded default. Must match the value used when secrets were originally
# stored — changing it invalidates all existing 2FA enrollments.
ENCRYPTION_KEY=dev_encryption_key_change_in_production
# Comma-separated CORS origin allowlist. The matching request Origin is reflected
# back (with credentials); never a wildcard. Defaults to http://localhost:3000.
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Maximum accepted API request-body size in bytes (WC-189). Bodies larger than
# this are rejected with a generic 400 before any parsing. Defaults to 1 MiB
# (1048576). A non-positive/non-numeric value falls back to the default.
MAX_REQUEST_BODY_BYTES=1048576
# Initial account passwords used during seeding/migration. If left unset, a random
# password is generated and printed ONCE to stdout/log so a fresh install is
# recoverable. There is no hardcoded fallback.
INITIAL_ADMIN_PASSWORD=
INITIAL_USER_PASSWORD=
INITIAL_SYSTEM_ADMIN_PASSWORD=
# Seeds the system-tenant (id 0) superuser superuser@example.com — a system-tenant
# admin that can manage the global base roles and every tenant.
INITIAL_SUPERUSER_PASSWORD=
