  "typography": {
    "fontFamily": {
      "sans": "'Noto Sans', 'Noto Sans Arabic', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "mono": "'Geist Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
      "heading": "'Noto Sans', 'Noto Sans Arabic', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
    },
    "fontFamilyDart": {
      "sans": "Noto Sans",
      "mono": "Geist Mono",
      "heading": "Noto Sans"
    },
    "scaleRationale": "Modular type scale anchored at 1rem (16px) base, stepping on an approximate minor-third (~1.2) ratio. Sizes expressed in rem for web (respects user zoom / root font-size) and resolved to px for Dart/Flutter (logical pixels).",
    "fontSize": {
      "xs": { "rem": "0.75rem", "px": 12 },
      "sm": { "rem": "0.875rem", "px": 14 },
      "base": { "rem": "1rem", "px": 16 },
      "lg": { "rem": "1.125rem", "px": 18 },
      "xl": { "rem": "1.25rem", "px": 20 },
      "2xl": { "rem": "1.5rem", "px": 24 },
      "3xl": { "rem": "1.875rem", "px": 30 },
      "4xl": { "rem": "2.25rem", "px": 36 }
    },
    "fontWeight": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "none": 1,
      "tight": 1.25,
      "snug": 1.375,
      "normal": 1.5,
      "relaxed": 1.625
    },
    "letterSpacing": {
      "tighter": "-0.05em",
      "tight": "-0.025em",
      "normal": "0em",
      "wide": "0.025em",
      "wider": "0.05em"
    }
  },
  "spacing": {
    "unit": "8px",
    "description": "8px base grid. The 4px step is a half-unit for fine adjustments.",
    "scale": {
      "0": "0px",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "6": "24px",
      "8": "32px"
    }
  },
  "borderRadius": {
    "base": "0.625rem",
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "12px",
    "2xl": "16px",
    "3xl": "20px",
    "4xl": "24px"
  },
  "accessibility": {
    "contrastRatio": "WCAG AA+",
    "colorSpace": "OKLCH",
    "description": "Perceptually uniform color space with verified accessibility compliance. The brand accent and all semantic colors are verified against their *-foreground pairs to meet WCAG AA (>=4.5:1) in both light and dark modes."
  },
  "brandAccent": {
    "hue": 255,
    "description": "Single restrained professional blue used for primary CTAs, links, active and focus states (drives primary, ring, sidebar-primary, chart-1). This is the white-label-overridable DEFAULT — tenants override --primary / --brand / --ring per docs/wiki/Theme-Customization.md. Light oklch(0.5 0.16 255) vs near-white foreground = 5.83:1; dark oklch(0.7 0.15 255) vs dark foreground = 6.68:1.",
    "verifiedContrast": {
      "lightOnForeground": 5.83,
      "darkOnForeground": 6.68
    }
  },
  "whiteLabelSupport": {
    "enabled": true,
    "approach": "CSS variable injection",
    "description": "Tokens can be customized per tenant at runtime via CSS variable override. The brand accent default (--primary / --brand / --ring) is intended to be overridden per tenant."
  }
}
