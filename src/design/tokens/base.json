{
  "name": "Whity Core Design Tokens",
  "description": "Master design token definitions for web, mobile, and desktop platforms. This file is the single source of truth — run `npm run tokens:generate` to regenerate all platform outputs (web globals.css, tokens.json, tokens.dart).",
  "version": "2.0.0",
  "platforms": {
    "web": {
      "type": "css-custom-properties",
      "location": "../../../web/app/globals.css",
      "description": "CSS variables used by Tailwind CSS v4 and shadcn-ui components. The :root / .dark / typography blocks are generated between AUTO-GENERATED sentinel markers."
    },
    "mobile": {
      "type": "dart-constants",
      "location": "./generated/tokens.dart",
      "description": "Dart constants for Flutter Material Design 3 integration"
    },
    "json": {
      "type": "json",
      "location": "./generated/tokens.json",
      "description": "Flat JSON export for programmatic / white-label tooling consumption"
    }
  },
  "colors": {
