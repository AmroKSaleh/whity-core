parameters:
    level: 0
    # Plugins are loaded at runtime by Whity\Core\PluginLoader's dynamic PSR-4
    # autoloader (directory name => namespace prefix), not by Composer. Tell
    # PHPStan where those symbols live so it can resolve plugin classes
    # referenced from the analysed test suite without analysing plugins/ itself.
    scanDirectories:
        - plugins
        # Migrations are loaded at runtime by MigrationsCommand (require of the
        # numbered file), not via Composer PSR-4. Point PHPStan at them so the
        # WC-54 real-engine test can reference its migration class for analysis.
        - database/migrations
