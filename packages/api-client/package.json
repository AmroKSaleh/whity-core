{
  "name": "@amroksaleh/api-client",
  "version": "0.1.0",
  "description": "Typed client for the Whity API, generated from its OpenAPI spec.",
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.d.ts"
  },
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "generate": "openapi-typescript ../../public/openapi.json -o src/schema.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^7"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
