{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "useDefineForClassFields": true,
    "module": "esnext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@amroksaleh/ui": ["../ui/src/index.ts"],
      "@amroksaleh/ui/*": ["../ui/src/*"],
      "@amroksaleh/features": ["../features/src/index.ts"],
      "@amroksaleh/features/*": ["../features/src/*"]
    }
  },
  "include": ["src"]
}
