{
  "name": "amroksaleh/whity-core",
  "description": "Open-source white-labeled multi-tenant platform framework",
  "type": "library",
  "license": "AGPL-3.0",
  "authors": [
    {
      "name": "Amro K. Saleh",
      "email": "amroksaleh@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.4",
    "psr/log": "^1.0 || ^2.0 || ^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "Whity\\Core\\": "src/Core/",
      "Whity\\Auth\\": "src/Auth/",
      "Whity\\Api\\": "src/Api/",
      "Whity\\Console\\": "src/Console/",
      "Whity\\Database\\": "src/Database/",
      "Whity\\Http\\": "src/Http/",
      "Whity\\Cli\\": "src/Cli/",
      "Whity\\Commands\\": "src/Commands/",
      "Whity\\OpenAPI\\": "src/OpenAPI/",
      "Whity\\Plugins\\": "plugins/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Whity\\Tests\\": "tests/",
      "Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
