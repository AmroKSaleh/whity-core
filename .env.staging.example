# Staging environment for docker-compose.staging.yml (WC-32).
#
# Copy to `.env.staging`, replace every secret with a real value, and pass it in:
#   docker compose -p whity-staging -f docker-compose.staging.yml \
#     --env-file .env.staging up -d --build
#
# Do NOT commit the populated `.env.staging` (it holds secrets). This *.example
# file ships placeholder/throwaway values only so the stack is reproducible.

# Prod-like: anything other than `development` engages the JWT/ENCRYPTION
# fail-fast guards in public/index.php. Use `staging`.
APP_ENV=staging

# --- Database ---------------------------------------------------------------
DB_USER=whity
DB_PASSWORD=whity_staging_pw_change_me
DB_NAME=whity_core
# Host-side port mappings (in-container Postgres still listens on 5432).
# Non-default so they never collide with the dev demo (:8000 / :5432).
APP_PORT_HOST=8100
DB_PORT_HOST=5433

# --- Security (MUST satisfy the prod-like guards) ---------------------------
# JWT_SECRET must be >= 32 characters outside development, else the worker
# refuses to boot. The values below are throwaway 40-char strings for local
# staging only — regenerate for any shared/remote staging host, e.g.:
#   openssl rand -hex 24
JWT_SECRET=staging_jwt_secret_0123456789abcdef0123
ENCRYPTION_KEY=staging_encryption_key_0123456789abcdef01

# Public base URL of the deployment (the externally-reachable origin, e.g. the
# reverse-proxy / tunnel host). REQUIRED for absolute URLs the backend cannot
# derive behind a proxy — notably the SSO/OIDC redirect_uri; leave it unset and
# federated sign-in fails with the provider rejecting a relative callback.
APP_URL=https://staging.example.com

# Explicit CORS allowlist (never a wildcard). Point at your staging web origin.
CORS_ALLOWED_ORIGINS=http://localhost:3100

# --- Seed credentials (consumed by `seed` + migration 010) ------------------
# Without these the seeder prints a random password once; set them so the
# load-test scripts have known logins.
INITIAL_ADMIN_PASSWORD=staging_admin_pw_change_me
INITIAL_USER_PASSWORD=staging_user_pw_change_me
INITIAL_SYSTEM_ADMIN_PASSWORD=staging_sysadmin_pw_change_me
# System-tenant (id 0) superuser superuser@example.com — manages global base roles.
INITIAL_SUPERUSER_PASSWORD=staging_superuser_pw_change_me

# --- Worker / pool tuning (override per load-test scenario) -----------------
FRANKENPHP_WORKERS=8
FRANKENPHP_TIMEOUT=60s
MAX_REQUESTS=500
DB_CONNECT_TIMEOUT=5
DB_MAX_LIFETIME=1800
DB_PING_INTERVAL=5
