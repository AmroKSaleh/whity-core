{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "useDefineForClassFields": true,
    "module": "esnext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@amroksaleh/ui": ["../../packages/ui/src/index.ts"],
      "@amroksaleh/ui/*": ["../../packages/ui/src/*"],
      "@amroksaleh/features": ["../../packages/features/src/index.ts"],
      "@amroksaleh/features/*": ["../../packages/features/src/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
